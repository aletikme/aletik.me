---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Posts" description="Blog posts by Andrey Letov.">
  <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-8">
    Posts
  </h1>

  <!-- Loading skeleton -->
  <div id="posts-skeleton" class="space-y-4">
    {
      [1, 2, 3, 4, 5].map(() => (
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-700/50">
          <div class="skeleton h-5 w-3/4 mb-2">&nbsp;</div>
          <div class="skeleton h-4 w-1/3 mb-3">&nbsp;</div>
          <div class="skeleton h-4 w-full">&nbsp;</div>
        </div>
      ))
    }
  </div>

  <!-- Posts list -->
  <div id="posts-list" class="hidden space-y-4"></div>

  <!-- Error state -->
  <div id="posts-error" class="hidden text-center py-16">
    <svg class="w-12 h-12 mx-auto text-slate-300 dark:text-slate-600 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"></path>
    </svg>
    <p class="text-slate-500 dark:text-slate-400 mb-2" id="error-message">Could not load posts.</p>
    <p class="text-sm text-slate-400 dark:text-slate-500">
      Check your GitHub config in <code class="bg-slate-100 dark:bg-slate-800 px-1.5 py-0.5 rounded text-xs">src/config.ts</code>
    </p>
  </div>

  <!-- Empty state -->
  <div id="posts-empty" class="hidden text-center py-16">
    <svg class="w-12 h-12 mx-auto text-slate-300 dark:text-slate-600 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"></path>
    </svg>
    <p class="text-slate-500 dark:text-slate-400 mb-2">No posts yet.</p>
    <p class="text-sm text-slate-400 dark:text-slate-500">
      Add markdown files to your GitHub blog repository to get started.
    </p>
  </div>
</BaseLayout>

<script>
  import { fetchPostList, formatDate, readingTime } from "../../lib/github";
  import { GITHUB_BLOG } from "../../config";

  const skeleton = document.getElementById("posts-skeleton")!;
  const list = document.getElementById("posts-list")!;
  const errorEl = document.getElementById("posts-error")!;
  const emptyEl = document.getElementById("posts-empty")!;

  async function loadPosts() {
    try {
      const posts = await fetchPostList(GITHUB_BLOG);

      skeleton.classList.add("hidden");

      if (posts.length === 0) {
        emptyEl.classList.remove("hidden");
        return;
      }

      // Group posts by year
      const grouped: Record<string, typeof posts> = {};
      for (const post of posts) {
        const year = post.date
          ? new Date(post.date).getFullYear().toString()
          : "Undated";
        if (!grouped[year]) grouped[year] = [];
        grouped[year].push(post);
      }

      const years = Object.keys(grouped).sort((a, b) => (b === "Undated" ? -1 : Number(b) - Number(a)));

      // Extract first image from markdown content
      function getFirstImage(content: string): string | null {
        const match = content.match(/!\[[^\]]*\]\(([^)]+)\)/);
        if (!match) return null;
        const src = match[1];
        if (src.startsWith("http")) return src;
        return `https://raw.githubusercontent.com/${GITHUB_BLOG.owner}/${GITHUB_BLOG.repo}/${GITHUB_BLOG.branch}/${GITHUB_BLOG.contentPath}/${src}`;
      }

      list.innerHTML = years
        .map(
          (year) => `
        <div class="mb-8">
          <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">${year}</h2>
          <div class="space-y-3">
            ${grouped[year]
              .map(
                (post) => {
                  const img = getFirstImage(post.content);
                  return `
              <a href="/post?slug=${encodeURIComponent(post.slug)}"
                 class="flex gap-4 p-4 rounded-lg border border-slate-200 dark:border-slate-700/50 hover:border-[var(--color-accent)] dark:hover:border-[var(--color-accent-dark)] hover:shadow-sm transition-all group">
                ${img ? `<img src="${img}" alt="" class="w-24 h-24 sm:w-28 sm:h-28 object-cover rounded-lg shrink-0" />` : ""}
                <div class="min-w-0">
                  <h3 class="font-semibold text-slate-900 dark:text-white group-hover:text-[var(--color-accent)] dark:group-hover:text-[var(--color-accent-dark)] transition-colors">
                    ${post.title}
                  </h3>
                  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-1 text-sm text-slate-500 dark:text-slate-400">
                    ${post.date ? `<time>${formatDate(post.date)}</time>` : ""}
                    <span>&middot;</span>
                    <span>${readingTime(post.content)} min read</span>
                    ${
                      post.tags.length > 0
                        ? `<span>&middot;</span><span class="text-xs">${post.tags.map((t: string) => `<span class="inline-block bg-slate-100 dark:bg-slate-800 px-2 py-0.5 rounded-full mr-1">${t}</span>`).join("")}</span>`
                        : ""
                    }
                  </div>
                  ${post.description ? `<p class="mt-2 text-sm text-slate-600 dark:text-slate-400 line-clamp-2">${post.description}</p>` : ""}
                </div>
              </a>
            `;
                },
              )
              .join("")}
          </div>
        </div>
      `,
        )
        .join("");

      list.classList.remove("hidden");
    } catch (err) {
      skeleton.classList.add("hidden");
      const msg = document.getElementById("error-message");
      if (msg && err instanceof Error) {
        msg.textContent = `Could not load posts: ${err.message}`;
      }
      errorEl.classList.remove("hidden");
      console.error("Failed to load posts:", err);
    }
  }

  loadPosts();
</script>
