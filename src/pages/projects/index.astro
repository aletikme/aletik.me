---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Projects" description="Projects by Andrey Letov.">
  <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-8">
    Projects
  </h1>

  <!-- Loading skeleton -->
  <div id="projects-skeleton" class="space-y-4">
    {
      [1, 2, 3, 4].map(() => (
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-700/50">
          <div class="skeleton h-5 w-3/4 mb-2">&nbsp;</div>
          <div class="skeleton h-4 w-1/3 mb-3">&nbsp;</div>
          <div class="skeleton h-4 w-full">&nbsp;</div>
        </div>
      ))
    }
  </div>

  <!-- Projects list -->
  <div id="projects-list" class="hidden space-y-4"></div>

  <!-- Error state -->
  <div id="projects-error" class="hidden text-center py-16">
    <svg class="w-12 h-12 mx-auto text-slate-300 dark:text-slate-600 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"></path>
    </svg>
    <p class="text-slate-500 dark:text-slate-400 mb-2" id="error-message">Could not load projects.</p>
    <p class="text-sm text-slate-400 dark:text-slate-500">
      Add markdown files to the <code class="bg-slate-100 dark:bg-slate-800 px-1.5 py-0.5 rounded text-xs">projects/</code> folder in the repo.
    </p>
  </div>

  <!-- Empty state -->
  <div id="projects-empty" class="hidden text-center py-16">
    <svg class="w-12 h-12 mx-auto text-slate-300 dark:text-slate-600 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z"></path>
    </svg>
    <p class="text-slate-500 dark:text-slate-400 mb-2">No projects yet.</p>
    <p class="text-sm text-slate-400 dark:text-slate-500">
      Add markdown files to the <code class="bg-slate-100 dark:bg-slate-800 px-1.5 py-0.5 rounded text-xs">projects/</code> folder in the repo.
    </p>
  </div>
</BaseLayout>

<script>
  import { fetchPostList, formatDate, readingTime } from "../../lib/github";
  import { GITHUB_PROJECTS } from "../../config";

  const skeleton = document.getElementById("projects-skeleton")!;
  const list = document.getElementById("projects-list")!;
  const errorEl = document.getElementById("projects-error")!;
  const emptyEl = document.getElementById("projects-empty")!;

  async function loadProjects() {
    try {
      const projects = await fetchPostList(GITHUB_PROJECTS);

      skeleton.classList.add("hidden");

      if (projects.length === 0) {
        emptyEl.classList.remove("hidden");
        return;
      }

      // Extract first image from markdown content
      function getFirstImage(content: string): string | null {
        const match = content.match(/!\[[^\]]*\]\(([^)]+)\)/);
        if (!match) return null;
        const src = match[1];
        if (src.startsWith("http")) return src;
        return `https://raw.githubusercontent.com/${GITHUB_PROJECTS.owner}/${GITHUB_PROJECTS.repo}/${GITHUB_PROJECTS.branch}/${GITHUB_PROJECTS.contentPath}/${src}`;
      }

      list.innerHTML = projects
        .map(
          (project) => {
            const img = getFirstImage(project.content);
            return `
          <a href="/project?slug=${encodeURIComponent(project.slug)}"
             class="flex gap-4 p-4 rounded-lg border border-slate-200 dark:border-slate-700/50 hover:border-[var(--color-accent)] dark:hover:border-[var(--color-accent-dark)] hover:shadow-sm transition-all group">
            ${img ? `<img src="${img}" alt="" class="w-24 h-24 sm:w-28 sm:h-28 object-cover rounded-lg shrink-0" />` : ""}
            <div class="min-w-0">
              <h3 class="font-semibold text-slate-900 dark:text-white group-hover:text-[var(--color-accent)] dark:group-hover:text-[var(--color-accent-dark)] transition-colors">
                ${project.title}
              </h3>
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-1 text-sm text-slate-500 dark:text-slate-400">
                ${project.date ? `<time>${formatDate(project.date)}</time>` : ""}
                <span>&middot;</span>
                <span>${readingTime(project.content)} min read</span>
                ${
                  project.tags.length > 0
                    ? `<span>&middot;</span><span class="text-xs">${project.tags.map((t: string) => `<span class="inline-block bg-slate-100 dark:bg-slate-800 px-2 py-0.5 rounded-full mr-1">${t}</span>`).join("")}</span>`
                    : ""
                }
              </div>
              ${project.description ? `<p class="mt-2 text-sm text-slate-600 dark:text-slate-400 line-clamp-2">${project.description}</p>` : ""}
            </div>
          </a>
        `;
          },
        )
        .join("");

      list.classList.remove("hidden");
    } catch (err) {
      skeleton.classList.add("hidden");
      const msg = document.getElementById("error-message");
      if (msg && err instanceof Error) {
        msg.textContent = `Could not load projects: ${err.message}`;
      }
      errorEl.classList.remove("hidden");
      console.error("Failed to load projects:", err);
    }
  }

  loadProjects();
</script>
