---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Post" description="Blog post by Andrey Letov.">
  <!-- Back link -->
  <a
    href="/posts"
    class="inline-flex items-center gap-1 text-sm text-slate-500 dark:text-slate-400 hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent-dark)] mb-6 transition-colors"
  >
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M19 12H5M12 19l-7-7 7-7"></path>
    </svg>
    Back to posts
  </a>

  <!-- Loading skeleton -->
  <div id="post-skeleton">
    <div class="skeleton h-8 w-3/4 mb-4">&nbsp;</div>
    <div class="skeleton h-4 w-1/3 mb-8">&nbsp;</div>
    <div class="space-y-3">
      <div class="skeleton h-4 w-full">&nbsp;</div>
      <div class="skeleton h-4 w-full">&nbsp;</div>
      <div class="skeleton h-4 w-5/6">&nbsp;</div>
      <div class="skeleton h-4 w-full">&nbsp;</div>
      <div class="skeleton h-4 w-4/5">&nbsp;</div>
    </div>
  </div>

  <!-- Post content -->
  <article id="post-article" class="hidden">
    <header class="mb-8">
      <h1 id="post-title" class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-3"></h1>
      <div id="post-meta" class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-slate-500 dark:text-slate-400"></div>
      <div id="post-tags" class="flex flex-wrap gap-2 mt-3"></div>
    </header>
    <div id="post-body" class="prose dark:text-slate-300"></div>
  </article>

  <!-- Error state -->
  <div id="post-error" class="hidden text-center py-16">
    <svg class="w-12 h-12 mx-auto text-slate-300 dark:text-slate-600 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"></path>
    </svg>
    <p class="text-slate-500 dark:text-slate-400 mb-2" id="error-message">Post not found.</p>
    <a href="/posts" class="text-sm text-[var(--color-accent)] dark:text-[var(--color-accent-dark)] hover:underline">
      &larr; View all posts
    </a>
  </div>
</BaseLayout>

<script>
  import { marked } from "marked";
  import {
    fetchPost,
    rewriteImagePaths,
    readingTime,
    formatDate,
  } from "../lib/github";
  import { GITHUB_BLOG } from "../config";

  const skeleton = document.getElementById("post-skeleton")!;
  const article = document.getElementById("post-article")!;
  const errorEl = document.getElementById("post-error")!;
  const titleEl = document.getElementById("post-title")!;
  const metaEl = document.getElementById("post-meta")!;
  const tagsEl = document.getElementById("post-tags")!;
  const bodyEl = document.getElementById("post-body")!;

  // Configure marked for safe rendering
  marked.setOptions({
    breaks: true,
    gfm: true,
  });

  async function loadPost() {
    const params = new URLSearchParams(window.location.search);
    const slug = params.get("slug");

    if (!slug) {
      skeleton.classList.add("hidden");
      const msg = document.getElementById("error-message");
      if (msg) msg.textContent = "No post specified.";
      errorEl.classList.remove("hidden");
      return;
    }

    try {
      const post = await fetchPost(slug, GITHUB_BLOG);

      if (!post) {
        skeleton.classList.add("hidden");
        errorEl.classList.remove("hidden");
        return;
      }

      // Set page title
      document.title = `${post.title} | Andrey Letov`;

      // Update meta tags
      const metaDesc = document.querySelector('meta[name="description"]');
      if (metaDesc && post.description) {
        metaDesc.setAttribute("content", post.description);
      }

      // Render header
      titleEl.textContent = post.title;

      const metaParts: string[] = [];
      if (post.date) metaParts.push(`<time>${formatDate(post.date)}</time>`);
      metaParts.push(`<span>${readingTime(post.content)} min read</span>`);
      metaEl.innerHTML = metaParts.join('<span class="text-slate-300 dark:text-slate-600">&middot;</span>');

      if (post.tags.length > 0) {
        tagsEl.innerHTML = post.tags
          .map(
            (tag) =>
              `<span class="inline-block text-xs bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 px-2.5 py-1 rounded-full">${tag}</span>`,
          )
          .join("");
      }

      // Render markdown with image path rewriting
      const rewritten = rewriteImagePaths(post.content, GITHUB_BLOG);
      bodyEl.innerHTML = await marked.parse(rewritten);

      // Style image captions: find <p> tags containing <img> followed by <em>
      bodyEl.querySelectorAll("p").forEach((p) => {
        const img = p.querySelector("img");
        const em = p.querySelector("em");
        if (img && em && p.childNodes.length <= 3) {
          // Move caption out into its own <p class="image-caption">
          const caption = document.createElement("p");
          caption.className = "image-caption";
          caption.textContent = em.textContent;
          // Keep only the image in the original <p>
          p.innerHTML = "";
          p.appendChild(img);
          p.after(caption);
        }
      });

      // Make external links open in new tab
      bodyEl.querySelectorAll("a").forEach((a) => {
        const href = a.getAttribute("href");
        if (href && href.startsWith("http")) {
          a.setAttribute("target", "_blank");
          a.setAttribute("rel", "noopener noreferrer");
        }
      });

      skeleton.classList.add("hidden");
      article.classList.remove("hidden");
    } catch (err) {
      skeleton.classList.add("hidden");
      const msg = document.getElementById("error-message");
      if (msg) msg.textContent = `Failed to load post: ${err instanceof Error ? err.message : "Unknown error"}`;
      errorEl.classList.remove("hidden");
      console.error("Failed to load post:", err);
    }
  }

  loadPost();
</script>
