---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, SOCIAL, GITHUB_BLOG } from "../config";
---

<BaseLayout>
  <!-- Hero section -->
  <section class="py-8 sm:py-16">
    <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6 sm:gap-8">
      <!-- Avatar placeholder — replace /avatar.jpg with your photo -->
      <div class="shrink-0">
        <a href="/about" class="block">
          <img
            src="/avatar.jpg"
            alt="Andrey Letov"
            class="w-24 h-24 sm:w-28 sm:h-28 rounded-full object-cover shadow-lg"
          />
        </a>
      </div>

      <div class="text-center sm:text-left">
        <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-2">
          Hi, I'm {SITE.author}
        </h1>
        <p class="text-lg text-slate-600 dark:text-slate-400 mb-4 max-w-xl">
          I design products and wrangle AI pipes. Building is the whole point.
        </p>
        <div class="flex items-center justify-center sm:justify-start gap-3">
          <a
            href={SOCIAL.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="text-slate-400 hover:text-slate-700 dark:hover:text-white transition-colors"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
            </svg>
          </a>
          <a
            href={SOCIAL.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="text-slate-400 hover:text-slate-700 dark:hover:text-white transition-colors"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
            </svg>
          </a>
          <a
            href={SOCIAL.email}
            aria-label="Email"
            class="text-slate-400 hover:text-slate-700 dark:hover:text-white transition-colors"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent posts (fetched from GitHub client-side) -->
  <section class="mt-4">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-bold text-slate-900 dark:text-white">
        Recent Posts
      </h2>
      <a
        href="/posts"
        class="text-sm font-medium text-[var(--color-accent)] dark:text-[var(--color-accent-dark)] hover:underline"
      >
        All Posts &rarr;
      </a>
    </div>

    <div id="recent-posts">
      <!-- Loading skeleton -->
      <div class="space-y-4" id="posts-skeleton">
        {
          [1, 2, 3].map(() => (
            <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-700/50">
              <div class="skeleton h-5 w-3/4 mb-2">&nbsp;</div>
              <div class="skeleton h-4 w-1/4 mb-3">&nbsp;</div>
              <div class="skeleton h-4 w-full">&nbsp;</div>
            </div>
          ))
        }
      </div>
      <div id="posts-list" class="hidden space-y-4"></div>
      <div id="posts-error" class="hidden text-center py-8 text-slate-500 dark:text-slate-400"></div>
      <div id="posts-empty" class="hidden text-center py-8 text-slate-500 dark:text-slate-400">
        <p class="mb-2">No posts yet.</p>
        <p class="text-sm">
          Create a GitHub repo and add markdown files to get started.
          See <code class="text-xs bg-slate-100 dark:bg-slate-800 px-1.5 py-0.5 rounded">src/config.ts</code> for setup.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  import { fetchPostList, formatDate, readingTime } from "../lib/github";
  import { GITHUB_BLOG } from "../config";

  const skeleton = document.getElementById("posts-skeleton")!;
  const list = document.getElementById("posts-list")!;
  const errorEl = document.getElementById("posts-error")!;
  const emptyEl = document.getElementById("posts-empty")!;

  async function loadRecentPosts() {
    try {
      const posts = await fetchPostList(GITHUB_BLOG);

      skeleton.classList.add("hidden");

      if (posts.length === 0) {
        emptyEl.classList.remove("hidden");
        return;
      }

      const recent = posts.slice(0, 5);

      // Extract first image from markdown content
      function getFirstImage(content: string, slug: string): string | null {
        const match = content.match(/!\[[^\]]*\]\(([^)]+)\)/);
        if (!match) return null;
        const src = match[1];
        if (src.startsWith("http")) return src;
        return `https://raw.githubusercontent.com/${GITHUB_BLOG.owner}/${GITHUB_BLOG.repo}/${GITHUB_BLOG.branch}/${GITHUB_BLOG.contentPath}/${src}`;
      }

      list.innerHTML = recent
        .map(
          (post) => {
            const img = getFirstImage(post.content, post.slug);
            return `
        <a href="/post?slug=${encodeURIComponent(post.slug)}"
           class="flex gap-4 p-4 rounded-lg border border-slate-200 dark:border-slate-700/50 hover:border-[var(--color-accent)] dark:hover:border-[var(--color-accent-dark)] hover:shadow-sm transition-all group">
          ${img ? `<img src="${img}" alt="" class="w-24 h-24 sm:w-28 sm:h-28 object-cover rounded-lg shrink-0" />` : ""}
          <div class="min-w-0">
            <h3 class="font-semibold text-slate-900 dark:text-white group-hover:text-[var(--color-accent)] dark:group-hover:text-[var(--color-accent-dark)] transition-colors">
              ${post.title}
            </h3>
            <div class="flex items-center gap-3 mt-1 text-sm text-slate-500 dark:text-slate-400">
              ${post.date ? `<time>${formatDate(post.date)}</time>` : ""}
              <span>&middot;</span>
              <span>${readingTime(post.content)} min read</span>
            </div>
            ${post.description ? `<p class="mt-2 text-sm text-slate-600 dark:text-slate-400 line-clamp-2">${post.description}</p>` : ""}
          </div>
        </a>
      `;
          },
        )
        .join("");
      list.classList.remove("hidden");
    } catch (err) {
      skeleton.classList.add("hidden");
      errorEl.textContent =
        "Could not load posts. Check your GitHub config in src/config.ts.";
      errorEl.classList.remove("hidden");
      console.error("Failed to load posts:", err);
    }
  }

  loadRecentPosts();
</script>
