---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Project" description="Project by Andrey Letov.">
  <!-- Back link -->
  <a
    href="/projects"
    class="inline-flex items-center gap-1 text-sm text-slate-500 dark:text-slate-400 hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent-dark)] mb-6 transition-colors"
  >
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M19 12H5M12 19l-7-7 7-7"></path>
    </svg>
    Back to projects
  </a>

  <!-- Loading skeleton -->
  <div id="project-skeleton">
    <div class="skeleton h-8 w-3/4 mb-4">&nbsp;</div>
    <div class="skeleton h-4 w-1/3 mb-8">&nbsp;</div>
    <div class="space-y-3">
      <div class="skeleton h-4 w-full">&nbsp;</div>
      <div class="skeleton h-4 w-full">&nbsp;</div>
      <div class="skeleton h-4 w-5/6">&nbsp;</div>
      <div class="skeleton h-4 w-full">&nbsp;</div>
      <div class="skeleton h-4 w-4/5">&nbsp;</div>
    </div>
  </div>

  <!-- Project content -->
  <article id="project-article" class="hidden">
    <header class="mb-8">
      <h1 id="project-title" class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-3"></h1>
      <div id="project-meta" class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-slate-500 dark:text-slate-400"></div>
      <div id="project-tags" class="flex flex-wrap gap-2 mt-3"></div>
    </header>
    <div id="project-body" class="prose dark:text-slate-300"></div>
  </article>

  <!-- Error state -->
  <div id="project-error" class="hidden text-center py-16">
    <svg class="w-12 h-12 mx-auto text-slate-300 dark:text-slate-600 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"></path>
    </svg>
    <p class="text-slate-500 dark:text-slate-400 mb-2" id="error-message">Project not found.</p>
    <a href="/projects" class="text-sm text-[var(--color-accent)] dark:text-[var(--color-accent-dark)] hover:underline">
      &larr; View all projects
    </a>
  </div>
</BaseLayout>

<script>
  import { marked } from "marked";
  import {
    fetchPost,
    rewriteImagePaths,
    readingTime,
    formatDate,
  } from "../lib/github";
  import { GITHUB_PROJECTS } from "../config";

  const skeleton = document.getElementById("project-skeleton")!;
  const article = document.getElementById("project-article")!;
  const errorEl = document.getElementById("project-error")!;
  const titleEl = document.getElementById("project-title")!;
  const metaEl = document.getElementById("project-meta")!;
  const tagsEl = document.getElementById("project-tags")!;
  const bodyEl = document.getElementById("project-body")!;

  marked.setOptions({
    breaks: true,
    gfm: true,
  });

  async function loadProject() {
    const params = new URLSearchParams(window.location.search);
    const slug = params.get("slug");

    if (!slug) {
      skeleton.classList.add("hidden");
      const msg = document.getElementById("error-message");
      if (msg) msg.textContent = "No project specified.";
      errorEl.classList.remove("hidden");
      return;
    }

    try {
      const project = await fetchPost(slug, GITHUB_PROJECTS);

      if (!project) {
        skeleton.classList.add("hidden");
        errorEl.classList.remove("hidden");
        return;
      }

      document.title = `${project.title} | Andrey Letov`;

      const metaDesc = document.querySelector('meta[name="description"]');
      if (metaDesc && project.description) {
        metaDesc.setAttribute("content", project.description);
      }

      titleEl.textContent = project.title;

      const metaParts: string[] = [];
      if (project.date) metaParts.push(`<time>${formatDate(project.date)}</time>`);
      metaParts.push(`<span>${readingTime(project.content)} min read</span>`);
      metaEl.innerHTML = metaParts.join('<span class="text-slate-300 dark:text-slate-600">&middot;</span>');

      if (project.tags.length > 0) {
        tagsEl.innerHTML = project.tags
          .map(
            (tag) =>
              `<span class="inline-block text-xs bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 px-2.5 py-1 rounded-full">${tag}</span>`,
          )
          .join("");
      }

      const rewritten = rewriteImagePaths(project.content, GITHUB_PROJECTS);
      bodyEl.innerHTML = await marked.parse(rewritten);

      bodyEl.querySelectorAll("a").forEach((a) => {
        const href = a.getAttribute("href");
        if (href && href.startsWith("http")) {
          a.setAttribute("target", "_blank");
          a.setAttribute("rel", "noopener noreferrer");
        }
      });

      skeleton.classList.add("hidden");
      article.classList.remove("hidden");
    } catch (err) {
      skeleton.classList.add("hidden");
      const msg = document.getElementById("error-message");
      if (msg) msg.textContent = `Failed to load project: ${err instanceof Error ? err.message : "Unknown error"}`;
      errorEl.classList.remove("hidden");
      console.error("Failed to load project:", err);
    }
  }

  loadProject();
</script>
